APP_NAME="Document Approval Workflow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite — no server needed, works in CI and local dev out of the box.
# The file is created by: touch database/database.sqlite
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Uncomment for MySQL / PostgreSQL in production:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=approval_workflow
# DB_USERNAME=root
# DB_PASSWORD=

# ── Queue ─────────────────────────────────────────────────────────────────────
# local dev  → database  (requires: php artisan queue:work)
# CI / tests → sync      (set in phpunit.xml, no worker needed)
# production → redis / sqs
QUEUE_CONNECTION=database

# ── Mail ─────────────────────────────────────────────────────────────────────
# local dev  → log    (emails written to storage/logs/laravel.log)
# CI / tests → array  (set in phpunit.xml, captured in memory)
# production → smtp / ses / postmark
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Cache & Session ───────────────────────────────────────────────────────────
# Keep as 'file' locally. Tests override to 'array' via phpunit.xml.
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ── Swagger / OpenAPI ─────────────────────────────────────────────────────────
# Set to false in production — generate the spec once and serve statically
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_DOC_EXPANSION=list
