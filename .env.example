APP_NAME="Document Approval Workflow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite for local dev — zero config
DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite
# For MySQL/Postgres in production:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=approval_workflow
# DB_USERNAME=root
# DB_PASSWORD=

# 'sync' in CI/tests — no worker needed
# 'database' for local dev (run: php artisan queue:work)
# 'redis' or 'sqs' for production
QUEUE_CONNECTION=database

# 'array' in CI — captured in memory, no SMTP
# 'log' for local dev — emails land in storage/logs/laravel.log
# 'smtp' or 'ses' for production
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# Swagger
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_DOC_EXPANSION=list
