<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <!-- These override .env during test runs — no .env.testing file needed -->
        <env name="APP_ENV"          value="testing"/>
        <env name="APP_KEY"          value="base64:2fl+Ktvkfl+Ktvkfl+Ktvkfl+Ktvkfl+Ktvkfl+Ktvk="/>
        <env name="APP_DEBUG"        value="true"/>

        <!-- SQLite in-memory: fast, isolated, no file to clean up -->
        <env name="DB_CONNECTION"    value="sqlite"/>
        <env name="DB_DATABASE"      value=":memory:"/>

        <!-- sync = queue jobs run immediately inline; no worker needed in tests -->
        <env name="QUEUE_CONNECTION" value="sync"/>

        <!-- array = mail is captured in memory; Mail::assertQueued() still works -->
        <env name="MAIL_MAILER"      value="array"/>

        <!-- Suppress bcrypt cost in tests for speed -->
        <env name="BCRYPT_ROUNDS"    value="4"/>

        <!-- Cache stays in-memory so tests don't share state via file cache -->
        <env name="CACHE_STORE"      value="array"/>

        <!-- Session in array so no cookie/file side-effects between tests -->
        <env name="SESSION_DRIVER"   value="array"/>
    </php>
</phpunit>
